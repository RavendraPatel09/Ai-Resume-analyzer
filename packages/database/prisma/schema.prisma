// =============================================================================
// AI Career Mentor — Prisma Schema
// PostgreSQL + pgvector (RAG embeddings live in `MemoryEntry.embedding`).
// Run: pnpm db:generate && pnpm db:migrate
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearchPostgres"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgvector(map: "vector")]
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
  SUPPORT
}

enum SubscriptionTier {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum FileType {
  PDF
  DOCX
  TXT
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum InterviewType {
  HR
  TECHNICAL
  BEHAVIORAL
  SYSTEM_DESIGN
}

enum InterviewStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum CoverLetterTone {
  PROFESSIONAL
  PERSONALIZED
  ATS_FRIENDLY
}

enum RoadmapHorizon {
  THREE_MONTH
  SIX_MONTH
  TWELVE_MONTH
  TWENTY_FOUR_MONTH
}

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum MemoryType {
  PROFILE
  SKILL
  GOAL
  RESUME
  INTERVIEW_RESULT
  RECOMMENDATION
  LEARNING_PROGRESS
  JOB_APPLICATION
  CONVERSATION_SUMMARY
  PREFERENCE
}

// The AI Activity Timeline action types.
enum ActivityType {
  RESUME_PARSED
  RESUME_SCORED
  ATS_SCAN_COMPLETED
  SKILL_GAP_DETECTED
  JOB_MATCH_GENERATED
  ROADMAP_GENERATED
  INTERVIEW_COMPLETED
  COVER_LETTER_GENERATED
  RECRUITER_INSIGHT_GENERATED
  CHAT_MESSAGE
  RECOMMENDATION_ISSUED
}

enum ActivityStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum RecommendationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DISMISSED
}

enum RecommendationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum JobApplicationStatus {
  SAVED
  APPLIED
  INTERVIEWING
  OFFER
  REJECTED
  ACCEPTED
}

// -----------------------------------------------------------------------------
// AUTH (NextAuth-compatible) + USER
// -----------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String? // null for OAuth-only accounts
  role          Role      @default(USER)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Domain relations
  profile          Profile?
  subscription     Subscription?
  resumes          Resume[]
  userSkills       UserSkill[]
  atsScans         AtsScan[]
  skillGaps        SkillGapAnalysis[]
  jobMatches       JobMatch[]
  jobApplications  JobApplication[]
  interviews       Interview[]
  coverLetters     CoverLetter[]
  roadmaps         Roadmap[]
  recruiterInsights RecruiterInsight[]
  memories         MemoryEntry[]
  activities       AiActivity[]
  recommendations  Recommendation[]
  progress         ProgressSnapshot[]
  conversations    ChatConversation[]
  auditLogs        AuditLog[]
  aiUsage          AiUsageRecord[]

  @@index([role])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Career profile — the structured "who the user is" record the AI reasons over.
model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  headline        String?
  bio             String?  @db.Text
  currentRole     String?
  currentCompany  String?
  yearsExperience Int?
  location        String?
  desiredRole     String?
  desiredSalaryMin Int?
  desiredSalaryMax Int?
  targetIndustries String[] @default([])
  careerGoals     String[] @default([])
  // Free-form structured prefs (work style, remote, relocation, etc.)
  preferences     Json     @default("{}")
  linkedinUrl     String?
  githubUrl       String?
  portfolioUrl    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// BILLING (admin revenue tracking)
// -----------------------------------------------------------------------------

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  tier                 SubscriptionTier   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([tier])
  @@index([status])
}

model Payment {
  id              String   @id @default(cuid())
  subscriptionId  String
  amountCents     Int
  currency        String   @default("usd")
  stripeInvoiceId String?  @unique
  status          String
  paidAt          DateTime?
  createdAt       DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// RESUMES (parser + builder)
// -----------------------------------------------------------------------------

model Resume {
  id             String           @id @default(cuid())
  userId         String
  title          String           @default("Untitled Resume")
  fileType       FileType?
  fileUrl        String? // S3 key for the original upload
  rawText        String?          @db.Text
  status         ProcessingStatus @default(PENDING)

  // Parsed/extracted fields
  fullName       String?
  email          String?
  phone          String?
  location       String?
  summary        String?          @db.Text
  // Structured parsed payload (skills/education/projects/experience/certs)
  parsed         Json             @default("{}")

  // Scoring
  score          Int? // 0-100 overall resume score
  scoreBreakdown Json             @default("{}") // { content, formatting, impact, keywords }
  weakAreas      String[]         @default([])
  recommendations String[]        @default([])

  isPrimary      Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions        ResumeVersion[]
  atsScans        AtsScan[]
  skillGaps       SkillGapAnalysis[]
  jobMatches      JobMatch[]
  coverLetters    CoverLetter[]
  extractedSkills UserSkill[]

  @@index([userId])
  @@index([status])
}

// Resume Builder versions (drag-and-drop document state + template).
model ResumeVersion {
  id         String   @id @default(cuid())
  resumeId   String
  label      String   @default("v1")
  templateId String   @default("modern")
  // Builder document tree (sections, blocks, styling)
  content    Json     @default("{}")
  pdfUrl     String? // S3 key of exported PDF
  docxUrl    String? // S3 key of exported DOCX
  createdAt  DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
}

// -----------------------------------------------------------------------------
// SKILLS + SKILL GAP
// -----------------------------------------------------------------------------

// Canonical skill taxonomy (shared, deduplicated).
model Skill {
  id        String      @id @default(cuid())
  name      String      @unique
  slug      String      @unique
  category  String? // e.g. "Programming", "Cloud", "Soft Skill"
  createdAt DateTime    @default(now())

  userSkills UserSkill[]

  @@index([category])
}

// A user's relationship to a skill (extracted or self-reported).
model UserSkill {
  id           String     @id @default(cuid())
  userId       String
  skillId      String
  resumeId     String?
  level        SkillLevel @default(INTERMEDIATE)
  // Inferred years from resume
  yearsUsed    Float?
  source       String     @default("resume") // resume | self | inferred
  createdAt    DateTime   @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill  Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)
  resume Resume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  @@unique([userId, skillId])
  @@index([userId])
  @@index([skillId])
}

model SkillGapAnalysis {
  id            String   @id @default(cuid())
  userId        String
  resumeId      String?
  targetRole    String
  // [{ skill, importance, hasSkill, gap, resources:[...] }]
  gaps          Json     @default("[]")
  matchedSkills String[] @default([])
  missingSkills String[] @default([])
  // Estimated time-to-ready in weeks
  weeksToReady  Int?
  learningPlan  Json     @default("{}")
  createdAt     DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// -----------------------------------------------------------------------------
// ATS SCANNER
// -----------------------------------------------------------------------------

model AtsScan {
  id                  String   @id @default(cuid())
  userId              String
  resumeId            String
  jobDescription      String?  @db.Text
  jobTitle            String?
  company             String?

  atsScore            Int // 0-100
  keywordMatchPercent Float
  matchedKeywords     String[] @default([])
  missingKeywords     String[] @default([])
  formattingIssues    Json     @default("[]") // [{ severity, message, fix }]
  suggestions         String[] @default([])
  report              Json     @default("{}") // full structured report for the visual UI
  createdAt           DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([resumeId])
}

// -----------------------------------------------------------------------------
// JOBS + JOB MATCH ENGINE
// -----------------------------------------------------------------------------

model Job {
  id             String   @id @default(cuid())
  externalId     String?  @unique
  title          String
  company        String
  location       String?
  remote         Boolean  @default(false)
  description    String   @db.Text
  requiredSkills String[] @default([])
  salaryMin      Int?
  salaryMax      Int?
  currency       String   @default("usd")
  source         String?  // greenhouse | lever | manual | ...
  url            String?
  postedAt       DateTime?
  createdAt      DateTime @default(now())

  matches      JobMatch[]
  applications JobApplication[]

  @@index([title])
  @@index([company])
}

model JobMatch {
  id                  String   @id @default(cuid())
  userId              String
  resumeId            String
  jobId               String?
  // For ad-hoc JD matching where there's no stored Job row
  jobTitle            String?
  company             String?
  matchPercent        Float
  compatibilityScore  Int // 0-100
  salaryMin           Int?
  salaryMax           Int?
  strengths           String[] @default([])
  weaknesses          String[] @default([])
  missingQualifications String[] @default([])
  createdAt           DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  job    Job?   @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resumeId])
}

model JobApplication {
  id        String               @id @default(cuid())
  userId    String
  jobId     String?
  title     String
  company   String
  status    JobApplicationStatus @default(SAVED)
  notes     String?              @db.Text
  appliedAt DateTime?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

// -----------------------------------------------------------------------------
// AI MOCK INTERVIEW
// -----------------------------------------------------------------------------

model Interview {
  id             String          @id @default(cuid())
  userId         String
  type           InterviewType
  role           String?
  status         InterviewStatus @default(SCHEDULED)

  // Aggregate scores (0-100)
  overallScore       Int?
  confidenceScore    Int?
  communicationScore Int?
  technicalScore     Int?

  // Media + transcript
  hasVoice    Boolean  @default(false)
  hasWebcam   Boolean  @default(false)
  recordingUrl String? // S3 key

  report      Json     @default("{}") // full Interview Report
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions InterviewQuestion[]

  @@index([userId])
  @@index([type])
}

model InterviewQuestion {
  id           String   @id @default(cuid())
  interviewId  String
  order        Int
  prompt       String   @db.Text
  category     String?
  // User's response
  answerText   String?  @db.Text
  answerAudioUrl String?
  // Per-question AI evaluation
  score        Int? // 0-100
  feedback     String?  @db.Text
  idealAnswer  String?  @db.Text
  createdAt    DateTime @default(now())

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId])
}

// -----------------------------------------------------------------------------
// COVER LETTERS
// -----------------------------------------------------------------------------

model CoverLetter {
  id             String          @id @default(cuid())
  userId         String
  resumeId       String?
  jobTitle       String?
  company        String?
  jobDescription String?         @db.Text
  tone           CoverLetterTone @default(PROFESSIONAL)
  content        String          @db.Text
  pdfUrl         String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// -----------------------------------------------------------------------------
// CAREER ROADMAP
// -----------------------------------------------------------------------------

model Roadmap {
  id          String         @id @default(cuid())
  userId      String
  title       String
  targetRole  String
  horizon     RoadmapHorizon
  summary     String?        @db.Text
  // Visual graph data (nodes/edges) for the roadmap renderer
  graph       Json           @default("{}")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones RoadmapMilestone[]

  @@index([userId])
}

model RoadmapMilestone {
  id          String          @id @default(cuid())
  roadmapId   String
  order       Int
  title       String
  description String?         @db.Text
  category    String // skills | certification | project | interview_prep | milestone
  status      MilestoneStatus @default(NOT_STARTED)
  dueWeek     Int? // week offset within the horizon
  resources   Json            @default("[]")
  completedAt DateTime?
  createdAt   DateTime        @default(now())

  roadmap Roadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([roadmapId])
}

// -----------------------------------------------------------------------------
// RECRUITER INSIGHTS
// -----------------------------------------------------------------------------

model RecruiterInsight {
  id              String   @id @default(cuid())
  userId          String
  targetRole      String
  perspective     String   @db.Text // recruiter POV narrative
  marketDemand    Json     @default("{}") // demand index, trend
  hiringTrends    String[] @default([])
  salaryTrends    Json     @default("{}")
  resumeWeaknesses String[] @default([])
  report          Json     @default("{}")
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// -----------------------------------------------------------------------------
// AI MEMORY CENTER  (long-term memory with pgvector embeddings)
// -----------------------------------------------------------------------------

model MemoryEntry {
  id         String     @id @default(cuid())
  userId     String
  type       MemoryType
  key        String // stable identifier, e.g. "career_goal", "skill:python"
  content    String     @db.Text // human-readable memory
  // Structured payload backing the memory
  data       Json       @default("{}")
  importance Int        @default(5) // 1-10, drives retrieval ranking + decay
  source     String     @default("system") // which feature wrote it
  // RAG embedding (OpenAI text-embedding-3-small = 1536 dims).
  embedding  Unsupported("vector(1536)")?
  lastUsedAt DateTime?
  expiresAt  DateTime? // optional TTL for transient memories
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId, type])
  @@index([userId, importance])
}

// -----------------------------------------------------------------------------
// AI ACTIVITY TRACKER  ("AI Activity Timeline" — Timeline / Kanban / Feed)
// -----------------------------------------------------------------------------

model AiActivity {
  id              String         @id @default(cuid())
  userId          String
  type            ActivityType
  status          ActivityStatus @default(SUCCEEDED)
  title           String
  description     String?        @db.Text
  // Stored input/output snapshots for auditability + replay
  input           Json           @default("{}")
  output          Json           @default("{}")
  confidenceScore Float? // 0-1
  // Link to the produced entity (resumeId, interviewId, etc.)
  entityType      String?
  entityId        String?
  durationMs      Int?
  errorMessage    String?
  createdAt       DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([status])
}

// -----------------------------------------------------------------------------
// NEXT ACTION ENGINE  (Recommendations)
// -----------------------------------------------------------------------------

model Recommendation {
  id            String                 @id @default(cuid())
  userId        String
  title         String
  rationale     String?                @db.Text
  // What feature/flow this points the user to
  actionType    String // e.g. "improve_resume", "apply_jobs", "practice_interview"
  actionPayload Json                   @default("{}")
  priority      RecommendationPriority @default(MEDIUM)
  status        RecommendationStatus   @default(PENDING)
  // The "after completion" follow-up suggestion
  nextStepHint  String?
  confidence    Float? // 0-1
  expiresAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, priority])
}

// -----------------------------------------------------------------------------
// PROGRESS TRACKING (analytics time-series)
// -----------------------------------------------------------------------------

model ProgressSnapshot {
  id               String   @id @default(cuid())
  userId           String
  resumeScore      Int?
  atsScore         Int?
  interviewScore   Int?
  jobMatchRate     Float?
  skillsMastered   Int      @default(0)
  learningProgress Float    @default(0) // 0-1 over active learning plan
  metrics          Json     @default("{}") // extensible bag for charts
  capturedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, capturedAt])
}

// -----------------------------------------------------------------------------
// CAREER CHATBOT (persistent mentor)
// -----------------------------------------------------------------------------

model ChatConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("New conversation")
  // Rolling AI-generated summary, fed back into context for long-term memory
  summary   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String // user | assistant | system | tool
  content        String   @db.Text
  // Tool calls / citations / token usage metadata
  metadata       Json     @default("{}")
  tokensIn       Int?
  tokensOut      Int?
  createdAt      DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// -----------------------------------------------------------------------------
// PLATFORM: AI usage metering, audit log
// -----------------------------------------------------------------------------

model AiUsageRecord {
  id          String   @id @default(cuid())
  userId      String?
  provider    String // anthropic | openai | gemini
  model       String
  feature     String // which feature triggered the call
  tokensIn    Int      @default(0)
  tokensOut   Int      @default(0)
  costCents   Float    @default(0)
  latencyMs   Int?
  success     Boolean  @default(true)
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([provider, createdAt])
  @@index([feature])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String // e.g. "user.login", "resume.delete", "admin.user.ban"
  resource   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action])
}
