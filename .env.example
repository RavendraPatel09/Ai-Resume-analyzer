# =============================================================================
# AI Career Mentor — Environment Configuration
# Copy to `.env` (root) and fill in. Never commit real secrets.
# =============================================================================

# --- Core ---
NODE_ENV=development

# --- Database (PostgreSQL) ---
# DATABASE_URL goes through the connection pooler (PgBouncer) in prod.
# DIRECT_URL is used by Prisma Migrate (direct connection).
DATABASE_URL="postgresql://acm:acm_password@localhost:5432/ai_career_mentor?schema=public"
DIRECT_URL="postgresql://acm:acm_password@localhost:5432/ai_career_mentor?schema=public"

# --- Redis (cache, rate limiting, BullMQ queues) ---
REDIS_URL="redis://localhost:6379"

# --- Auth (NextAuth + backend JWT) ---
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET="replace-with-openssl-rand-base64-32"
JWT_REFRESH_SECRET="replace-with-another-openssl-rand-base64-32"
JWT_ACCESS_TTL="900"            # 15 minutes (seconds)
JWT_REFRESH_TTL="1209600"       # 14 days (seconds)

# --- OAuth Providers ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- AI Providers ---
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_GENAI_API_KEY=""
# Default model routing (override per-feature in code)
AI_DEFAULT_PROVIDER="anthropic"          # anthropic | openai | gemini
AI_DEFAULT_MODEL="claude-opus-4-8"
AI_EMBEDDING_MODEL="text-embedding-3-large"

# --- Vector store (RAG). Uses pgvector inside the same Postgres by default. ---
VECTOR_BACKEND="pgvector"                 # pgvector | pinecone | qdrant
PINECONE_API_KEY=""
PINECONE_INDEX=""

# --- AWS S3 (resume/file storage) ---
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET="ai-career-mentor-uploads"
S3_SIGNED_URL_TTL="300"

# --- Monitoring ---
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_LOGROCKET_ID=""

# --- Frontend → Backend ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
API_PORT="4000"
WEB_PORT="3000"

# --- Rate limiting ---
RATE_LIMIT_TTL="60"
RATE_LIMIT_MAX="100"

# --- Billing (Stripe — admin revenue tracking) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
